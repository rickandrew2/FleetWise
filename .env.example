# =========================
# Core Database + Docker
# =========================
DB_URL=jdbc:postgresql://localhost:5432/fleetwise
DB_USERNAME=postgres
DB_PASSWORD=postgres
POSTGRES_DB=fleetwise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =========================
# App + Auth
# =========================
SERVER_PORT=8080
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =========================
# Route Planning (GraphHopper)
# =========================
GRAPHHOPPER_BASE_URL=https://graphhopper.com/api/1/route
GRAPHHOPPER_API_KEY=
GRAPHHOPPER_VEHICLE=car

# =========================
# Fuel Price Tracker
# =========================
FUEL_PRICE_SOURCE_URL=https://fuelprice.ph
FUEL_PRICE_SCHEDULER_ENABLED=true
FUEL_PRICE_SCHEDULER_CRON=0 0 8 * * TUE
FUEL_PRICE_SCHEDULER_ZONE=Asia/Manila
FUEL_PRICE_STALE_AFTER_DAYS=8

# =========================
# Alert Thresholds
# =========================
ALERT_HIGH_COST_THRESHOLD=5000
ALERT_OVERCONSUMPTION_THRESHOLD=1.25
ALERT_UNUSUAL_FILLUP_MULTIPLIER=1.10

# =========================
# Reports
# =========================
REPORTS_OUTPUT_PATH=target/reports-output
REPORTS_SCHEDULER_ENABLED=false
REPORTS_SCHEDULER_WEEKLY_CRON=0 0 9 * * MON
REPORTS_SCHEDULER_MONTHLY_CRON=0 0 9 1 * *

# =========================
# Email Notifications (default: local Mailpit)
# =========================
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_FROM=noreply@fleetwise.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# Gmail SMTP override example:
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_gmail@gmail.com
# MAIL_PASSWORD=your_google_app_password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
# EMAIL_FROM=your_gmail@gmail.com